---
import { buildToc } from '@root/utils';
import type { MarkdownHeading } from 'astro';

const { headings } = Astro.props;

interface Props {
  headings: MarkdownHeading[];
}

const toc = buildToc(headings);
---

<nav class="toc not-prose my-8 rounded-xl border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900/60 overflow-hidden text-sm">
  <details class="group/toc" data-toc-root open>
    <summary class="px-4 py-3 border-b border-neutral-200 dark:border-neutral-800 flex items-center gap-2 cursor-pointer select-none list-none hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors duration-150">
      <svg class="w-3.5 h-3.5 text-violet-500 dark:text-fuchsia-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h10M4 18h12"/>
      </svg>
      <span class="font-mono text-xs font-semibold uppercase tracking-wider text-violet-600 dark:text-fuchsia-400 flex-1">
        On this page
      </span>
      <svg class="w-3.5 h-3.5 text-neutral-400 dark:text-neutral-600 transition-transform duration-200 group-open/toc:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </summary>

  <ul class="py-2 px-2 list-none m-0 space-y-px">
    {toc.map((heading) => (
      <li class="m-0">
        {heading.subheadings.length > 0 ? (
          <details class="group/d" open>
            <summary class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg cursor-pointer list-none select-none hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors duration-150">
              <svg
                class="w-3 h-3 flex-shrink-0 text-neutral-400 dark:text-neutral-600 transition-transform duration-200 group-open/d:rotate-90"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
              <a
                href={'#' + heading.slug}
                data-toc-link={'#' + heading.slug}
                class="flex-1 font-medium text-neutral-700 dark:text-neutral-200 hover:text-violet-600 dark:hover:text-fuchsia-400 no-underline transition-colors duration-150"
                onclick="event.stopPropagation()"
              >
                {heading.text}
              </a>
            </summary>
            <ul class="mt-0.5 ml-4 pl-3 border-l border-neutral-200 dark:border-neutral-800 list-none m-0 space-y-px">
              {heading.subheadings.map((sub) => (
                <li class="m-0">
                  <a
                    href={'#' + sub.slug}
                    data-toc-link={'#' + sub.slug}
                    class="block px-2.5 py-1 rounded-lg text-xs text-neutral-500 dark:text-neutral-400 hover:text-violet-600 dark:hover:text-fuchsia-400 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-all duration-150 no-underline"
                  >
                    {sub.text}
                  </a>
                </li>
              ))}
            </ul>
          </details>
        ) : (
          <a
            href={'#' + heading.slug}
            data-toc-link={'#' + heading.slug}
            class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg font-medium text-neutral-700 dark:text-neutral-200 hover:text-violet-600 dark:hover:text-fuchsia-400 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-all duration-150 no-underline"
          >
            <span class="w-3 h-3 flex-shrink-0 inline-block"></span>
            {heading.text}
          </a>
        )}
      </li>
    ))}
  </ul>
  </details>
</nav>

<script>
  function initToc() {
    const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
    const headings = document.querySelectorAll<HTMLElement>('article h2[id], article h3[id]');

    if (!links.length || !headings.length) return;

    const setActive = (id: string) => {
      links.forEach((link) => {
        const isActive = link.getAttribute('data-toc-link') === '#' + id;
        link.classList.toggle('toc-active', isActive);
        if (isActive) {
          const details = link.closest('details:not([data-toc-root])');
          if (details) details.open = true;
        }
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
            break;
          }
        }
      },
      { rootMargin: '-80px 0% -60% 0%', threshold: 0 }
    );

    headings.forEach((h) => observer.observe(h));
  }

  initToc();
  document.addEventListener('astro:after-swap', initToc);
</script>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  :target::before {
    content: '';
    display: block;
    height: 80px;
    margin-top: -80px;
    visibility: hidden;
  }

  .anchor {
    display: inline-block;
    text-decoration: none;
  }

  .anchor i {
    visibility: hidden;
    font-size: 1.25rem;
    padding-left: 0.5rem;
  }

  h1:hover .anchor i,
  h2:hover .anchor i,
  h3:hover .anchor i,
  h4:hover .anchor i,
  h5:hover .anchor i,
  h6:hover .anchor i {
    visibility: visible;
  }

  details summary::-webkit-details-marker {
    display: none;
  }

  .toc-active {
    color: #7c3aed !important;
    background-color: #f5f3ff !important;
    font-weight: 600 !important;
  }

  .dark .toc-active {
    color: #e879f9 !important;
    background-color: rgb(232 121 249 / 0.1) !important;
  }
</style>
